# OpenRouter example
OPENAI_API_KEY=your_openrouter_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
MODEL_NAME=openai/gpt-4o-mini

# LM Studio example
# OPENAI_API_KEY=lm-studio
# OPENAI_BASE_URL=http://localhost:1234/v1
# MODEL_NAME=qwen3-32b


# Assignment 2 Part 3 - RunPod hub config
HUB_BASE_URL=https://example.proxy.runpod.net
HUB_PASSWORD=
HUB_AGENT_NAME=lullo-swe-agent
HUB_POLL_INTERVAL_SECONDS=1.2

# Safety controls for hub loop
# true = print response locally without posting to hub
# false = post real responses to hub
HUB_DRY_RUN=true
HUB_MAX_RESPONSES_PER_RUN=3

# Optional LLM responder for hub collaboration
HUB_USE_LLM_RESPONDER=false
HUB_RESPONDER_MAX_TOKENS=200

# Controls how the hub agent handles task-like messages.
# review_only = respond with suggestions only, no local task approval flow.
# manual_approval = queue task-like messages for local approval before any action.
HUB_EXECUTION_MODE=review_only
# Alternative:
# HUB_EXECUTION_MODE=manual_approval

# Approved hub task runner
# placeholder = show approved task package only, no local agent execution.
# part2_agent = run the approved task through the local Part 2 SWE-agent after /approve.
HUB_APPROVED_TASK_RUNNER=placeholder