# Assignment 2 Part 3 - RunPod hub config
HUB_BASE_URL=https://example.proxy.runpod.net
HUB_PASSWORD=
HUB_AGENT_NAME=lullo-swe-agent
HUB_POLL_INTERVAL_SECONDS=1.2



# Safety controls for hub loop
HUB_DRY_RUN=true # agent writes what it would send, but does not post to hub
HUB_MAX_RESPONSES_PER_RUN=3



# Optional LLM responder for hub collaboration
HUB_USE_LLM_RESPONDER=false
HUB_RESPONDER_MAX_TOKENS=200


# Optional LLM responder for hub collaboration
HUB_USE_LLM_RESPONDER=false
HUB_RESPONDER_MAX_TOKENS=200